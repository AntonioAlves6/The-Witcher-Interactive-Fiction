        <command xml:space="preserve">examine black potion</command>
        <result xml:space="preserve">Maybe you should ask the herbalist about the monster first... No?

&gt;</result>
        <commentary xml:space="preserve"></commentary>
        <children><child nodeId="node-2217"></child>
        </children>
    </item>
