    <item nodeId="node-1853">
        <command xml:space="preserve">examine barber</command>
        <result xml:space="preserve">He sharpens a razor on a leather strap, though he keeps glancing toward the north, toward the palace district.

&gt;</result>
        <commentary xml:space="preserve"></commentary>
